# Environment
APP_NAME=FinFlow AI API
APP_ENV=development
APP_DEBUG=true
API_V1_PREFIX=/api/v1

# Database
DATABASE_URL=sqlite:///./finflow.db

# Security
AUTH_ENABLED=false
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
CORS_ALLOW_ORIGINS=*

# AI provider switch: claude | gemini | grok
AI_PROVIDER=claude

# Optional provider keys
CLAUDE_API_KEY=
GEMINI_API_KEY=
GROK_API_KEY=
